# Lexio — environment variables
# Copy this file to .env.local for local development. In production these
# are set in Vercel → Project Settings → Environment Variables.

# Fish Audio API key. Without this, the app falls back to the browser's
# built-in speechSynthesis (no error, just lower-quality voice).
VITE_FISH_AUDIO_API_KEY=

# Optional: override the default voice id. If unset, Fish Audio uses
# whatever default the account is configured with.
VITE_FISH_AUDIO_VOICE_ID=
