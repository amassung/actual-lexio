# Lexio — environment variables
# Copy this file to .env.local for local development. In production these
# are set in Vercel → Project Settings → Environment Variables.

# ElevenLabs API key. Without this, the app falls back to the browser's
# built-in speechSynthesis (no error, just lower-quality voice).
# Get one at: https://elevenlabs.io → Workspace settings → API Keys
VITE_ELEVENLABS_API_KEY=

# The voice id of the cloned "Lexio Teacher" voice. Optional — the app
# falls back to a hardcoded default in src/services/tts.ts if unset.
VITE_ELEVENLABS_VOICE_ID=gwN3hEbGhE9zHBbp2V10

# Optional: override the model. Default is eleven_turbo_v2_5 — fast and
# crisp, ideal for phonics. Use eleven_multilingual_v2 for higher quality
# at the cost of latency.
VITE_ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
